{
  "name": "milkslop",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Standalone WebGL port of the MilkDrop 2 music visualizer",
  "license": "BSD-3-Clause",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && node scripts/check-tsdoc.mjs",
    "doc:check": "node scripts/check-tsdoc.mjs",
    "fix": "npm run fix:eslint && npm run fix:prettier",
    "fix:eslint": "eslint --fix .",
    "fix:prettier": "prettier -w .",
    "smoke": "node scripts/smoke.mjs",
    "check-shaders": "node scripts/check-shaders.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-plugin-tsdoc": "^0.5.2",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "js-yaml": "^5.2.1",
    "playwright": "^1.61.1",
    "prettier": "^3.9.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.8"
  }
}
